# --- Database (Neon Postgres) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/db?sslmode=require

# --- Auth.js v5 ---
# Generate with: npx auth secret  (or `openssl rand -base64 32`)
AUTH_SECRET=

# Used for magic links and notification emails (Resend)
AUTH_RESEND_KEY=
RESEND_API_KEY=          # same value as AUTH_RESEND_KEY; Resend SDK reads this
EMAIL_FROM="Hackathon <noreply@example.com>"

# --- App ---
# Public URL of the deployed app (used in emails and judge invite URLs)
APP_URL=http://localhost:3000

# Comma-separated list of admin emails (case-insensitive). Defaults to
# shali.mor@forcepoint.com if unset.
ADMIN_EMAILS=shali.mor@forcepoint.com,benny.zemmour@forcepoint.com,sscarlat@forcepoint.com,eyal@native.security,froyke@gmail.com,tal.shapiro@fundguard.com

# --- Judges ---
# HS256 secret for judge JWT tokens. Generate: openssl rand -base64 48
JUDGE_TOKEN_SECRET=
